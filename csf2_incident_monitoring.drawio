        </mxCell>

        <mxCell id="laneL2" value="L2 Triage"
                style="shape=swimlane;html=1;startSize=30;horizontal=0;collapsible=0;swimlaneFillColor=#ffffff;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="40" y="650" width="820" height="240" as="geometry" />
        </mxCell>

        <mxCell id="laneIM" value="Incident Manager / EMT"
                style="shape=swimlane;html=1;startSize=30;horizontal=0;collapsible=0;fillColor=#f5f5f5;swimlaneFillColor=#ffffff;fontStyle=1;"
