             Left column center x = 240 (shape x=170, w=160).
             =========================================================== -->

        <!-- 01 Start (Source lane: 90..190) -->
        <mxCell id="n01" value="01. Adverse event&#10;detected" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
