<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" agent="ProcessDiagramSkill">
  <diagram name="CSF 2.0 Incident Monitoring">
    <mxGraphModel grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="900" pageHeight="2000" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ===========================================================
             HORIZONTAL TITLE (top of page)
             =========================================================== -->
        <mxCell id="titleBar" value="Security Incident Monitoring Process&#10;(NIST CSF 2.0: Detect / Respond / Recover)"
                style="rounded=0;whiteSpace=wrap;html=1;fillColor=#e1e7ef;strokeColor=#6c8ebf;fontSize=15;fontStyle=1;align=center;verticalAlign=middle;"
                vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="820" height="50" as="geometry" />
        </mxCell>

        <!-- ===========================================================
             SWIMLANES (top-level, stacked vertically, vertical title on left)
             Each lane is a swimlane with horizontal=0 so its title bar
             is rendered as a vertical strip on the LEFT side of the lane.
             startSize=30 -> title bar width = 30 px.
             Page-y origin for lanes: 90 (title 20..70 + 20 gap)
             Lane heights (chosen to fit content + padding):
               Source: 100  -> 90..190
               L1:     240  -> 190..430
               SIEM:   220  -> 430..650
               L2:     240  -> 650..890
               IM:     220  -> 890..1110
               L3:     320  -> 1110..1430
               RC:     300  -> 1430..1730
             Each lane: x=40, width=820. Content (shapes) sit at x >= 40+30=70.
             =========================================================== -->

        <mxCell id="laneSource" value="Incident Source"
                style="shape=swimlane;html=1;startSize=30;horizontal=0;collapsible=0;fillColor=#f5f5f5;swimlaneFillColor=#ffffff;fontStyle=1;"
                vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="820" height="100" as="geometry" />
        </mxCell>

        <mxCell id="laneL1" value="Service Desk L1"
                style="shape=swimlane;html=1;startSize=30;horizontal=0;collapsible=0;swimlaneFillColor=#ffffff;fontStyle=1;"
